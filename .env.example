# --- Auth ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
BCRYPT_ROUNDS=12
JWT_SECRET=change-me-in-production-please
JWT_TTL_HOURS=12

# --- Keycloak (Step 1: service only; realm wiring lands in Step 2) ---
# Admin console will be at http://localhost:8080
# These bootstrap the master-realm admin user on first start.
KEYCLOAK_ADMIN=adminn
KEYCLOAK_ADMIN_PASSWORD=admin123
# Used by backend / frontend in later steps (Step 3+):
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=deepcampus
KEYCLOAK_CLIENT_ID=streamlit-app

# --- LLM (Ollama) ---
LLM_MODEL=llama3.1:8b-instruct-q8_0
AVAILABLE_LLMS=llama3.1:8b-instruct-q8_0,qwen2.5:14b-instruct-q4_K_M,gemma2:9b-instruct-q4_K_M
OLLAMA_HOST=http://ollama:11434

# --- Embeddings (BGE-M3) ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_USE_FP16=true

# --- VLM (Moondream2) ---
VLM_MODEL=vikhyatk/moondream2
VLM_REVISION=2024-08-26

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=deepcampus
QDRANT_USE_GRPC=false
QDRANT_API_KEY=

# --- RAG tuning ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K=20
RERANK_TOP_N=8
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4
RRF_K=60
MIN_IMAGE_BYTES=15000
MIN_TEXT_CHARS=15
TEMPERATURE=0.3
HISTORY_WINDOW=4

# --- Backend / Frontend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000

# --- Logging ---
LOG_LEVEL=INFO
