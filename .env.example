# --- Auth ---
# Change these in production. The default admin account is created on first run only.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
BCRYPT_ROUNDS=12

# --- Models ---
LLM_MODEL=llama3.1:8b-instruct-q8_0
OLLAMA_HOST=http://ollama:11434
EMBEDDING_MODEL=intfloat/multilingual-e5-base
VLM_MODEL=vikhyatk/moondream2
VLM_REVISION=2024-08-26
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_ENABLED=true

# --- RAG tuning ---
CHUNK_SIZE=300
CHUNK_OVERLAP=50
TOP_K=15
RERANK_TOP_N=6
MIN_IMAGE_BYTES=15000
MIN_TEXT_CHARS=15
TEMPERATURE=0.3
HISTORY_WINDOW=4

# --- Paths (override only inside containers) ---
# USER_DB_PATH=/app/data/user.db
# INGEST_STATE_PATH=/app/data/ingest_state.json
# DOCS_PATH=/app/docs
# CHROMA_DB_PATH=/app/chroma_db
# DOCS_IMAGES_PATH=/app/docs_images

# --- Logging ---
LOG_LEVEL=INFO
